# Supabase — backend database and auth
# Get these from your Supabase project dashboard: https://app.supabase.com
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# OpenWeatherMap API — beach weather conditions
# Sign up at https://openweathermap.org/api
EXPO_PUBLIC_OWM_API_KEY=your_openweathermap_key

# Flickr API — beach photos
# Get your API key at https://www.flickr.com/services/apps/create/
EXPO_PUBLIC_FLICKR_API_KEY=your_flickr_key

# Unsplash API — high-quality beach imagery
# Register at https://unsplash.com/developers
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_key

# Google AdMob — in-app advertising
# Create your app in AdMob console: https://admob.google.com
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxxxxx~xxxxxxxx
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-xxxxxxxx~xxxxxxxx

# RevenueCat — in-app purchases and subscriptions
# Get your API keys at https://app.revenuecat.com
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxx
